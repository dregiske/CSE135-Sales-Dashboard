<%- include('components/header') %>
<%- include('components/navbar') %>

<div class="container">
    <h1>Dashboard</h1>

    <div class="cards">
        <div class="card">
            <h3>Total Revenue</h3>
            <p>$<%= totalRevenue.toFixed(2) %></p>
        </div>
        <div class="card">
            <h3>Total Orders</h3>
            <p><%= totalOrders %></p>
        </div>
        <div class="card">
            <h3>Total Customers</h3>
            <p><%= totalCustomers %></p>
        </div>
        <div class="card">
            <h3>Pending Orders</h3>
            <p><%= pendingOrders %></p>
        </div>
    </div>

    <div class="charts">
        <div class="chart-container">
            <canvas id="monthlyRevenueChart"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="ordersByStatusChart"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="revenueByRegionChart"></canvas>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Parse data passed from controller
    const monthlyRevenue  = JSON.parse('<%- monthlyRevenue %>');
    const ordersByStatus  = JSON.parse('<%- ordersByStatus %>');
    const revenueByRegion = JSON.parse('<%- revenueByRegion %>');

    // Monthly Revenue Bar Chart
    new Chart(document.getElementById('monthlyRevenueChart'), {
        type: 'bar',
        data: {
            labels: monthlyRevenue.map(r => r.month),
            datasets: [{
                label: 'Monthly Revenue',
                data: monthlyRevenue.map(r => r.total_revenue),
                backgroundColor: 'rgba(54, 162, 235, 0.6)'
            }]
        }
    });

    // Orders by Status Pie Chart
    new Chart(document.getElementById('ordersByStatusChart'), {
        type: 'pie',
        data: {
            labels: ordersByStatus.map(r => r.status),
            datasets: [{
                data: ordersByStatus.map(r => r.count),
                backgroundColor: [
                    'rgba(75, 192, 192, 0.6)',
                    'rgba(255, 206, 86, 0.6)',
                    'rgba(255, 99, 132, 0.6)'
                ]
            }]
        }
    });

    // Revenue by Region Bar Chart
    new Chart(document.getElementById('revenueByRegionChart'), {
        type: 'bar',
        data: {
            labels: revenueByRegion.map(r => r.region),
            datasets: [{
                label: 'Revenue by Region',
                data: revenueByRegion.map(r => r.total_revenue),
                backgroundColor: 'rgba(153, 102, 255, 0.6)'
            }]
        }
    });
</script>
</body>
</html>
