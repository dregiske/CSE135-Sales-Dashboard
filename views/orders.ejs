<%- include('components/header') %>
<%- include('components/navbar') %>

<div class="container">
    <h1>Orders</h1>

    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Product</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Date</th>
            </tr>
        </thead>
        <tbody>
            <% orders.forEach(order => { %>
            <tr>
                <td><%= order.id %></td>
                <td><%= order.customer_name %></td>
                <td><%= order.product %></td>
                <td>$<%= order.amount.toFixed(2) %></td>
                <td><%= order.status %></td>
                <td><%= order.order_date %></td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>
<%- include('components/footer') %>