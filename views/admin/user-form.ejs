<%- include('../components/header') %>
<%- include('../components/navbar') %>

<div class="container">
    <div class="page-header">
        <h1><%= editUser ? 'Edit User' : 'New User' %></h1>
        <a href="/admin/users" class="btn">← Back to Users</a>
    </div>

    <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>

    <div class="form-card">
        <form action="/admin/users/<%= editUser ? editUser.id + '/edit' : 'new' %>" method="POST">
            <div class="form-group">
                <label>Username</label>
                <% if (editUser) { %>
                    <input type="text" value="<%= editUser.username %>" disabled />
                <% } else { %>
                    <input type="text" name="username" required />
                <% } %>
            </div>

            <div class="form-group">
                <label>Password <%= editUser ? '<span class="label-hint">(leave blank to keep current)</span>' : '' %></label>
                <input type="password" name="password" <%= editUser ? '' : 'required' %> />
            </div>

            <div class="form-group">
                <label>Role</label>
                <select name="role" class="form-select">
                    <option value="superadmin" <%= editUser && editUser.role === 'superadmin' ? 'selected' : '' %>>Super Admin</option>
                    <option value="analyst"    <%= editUser && editUser.role === 'analyst'    ? 'selected' : '' %>>Analyst</option>
                    <option value="viewer"     <%= editUser && editUser.role === 'viewer'     ? 'selected' : '' %>>Viewer</option>
                </select>
            </div>

            <div class="form-group">
                <label>Sections <span class="label-hint">(analysts only)</span></label>
                <div class="sections-grid">
                    <% sections.forEach(section => { %>
                    <label class="checkbox-label">
                        <input type="checkbox" name="sections" value="<%= section %>"
                            <%= editUser && editUser.sections.includes(section) ? 'checked' : '' %> />
                        <%= section %>
                    </label>
                    <% }) %>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary"><%= editUser ? 'Save Changes' : 'Create User' %></button>
                <a href="/admin/users" class="btn">Cancel</a>
            </div>
        </form>
    </div>
</div>

<%- include('../components/footer') %>
